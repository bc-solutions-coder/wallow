# =============================================================================
# Wallow Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values marked CHANGE_ME or REQUIRED.
# Generate secrets with: openssl rand -base64 32
#
# .NET config override syntax: Section__Key maps to { "Section": { "Key": "" } }
# Array syntax: Key__0, Key__1, Key__2, etc.
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=wallow
ASPNETCORE_ENVIRONMENT=Production

# -----------------------------------------------------------------------------
# APPLICATION IMAGE
# -----------------------------------------------------------------------------
# The Docker image to pull. Set APP_TAG to the release version you want to deploy.
APP_IMAGE=ghcr.io/bc-solutions-coder/wallow
APP_TAG=latest

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_USER=wallow
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=wallow

# -----------------------------------------------------------------------------
# VALKEY (Redis-compatible cache + SignalR backplane)
# -----------------------------------------------------------------------------
VALKEY_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# JWT / SIGNING KEYS (REQUIRED — app won't start without these)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 48
Identity__SigningKey=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# -----------------------------------------------------------------------------
# SERVICE URLS (REQUIRED — must match your domain / reverse proxy setup)
# -----------------------------------------------------------------------------
# These are the public-facing URLs your users will access.
# If running behind a reverse proxy (nginx, Caddy, Traefik), these are the
# external URLs, not the internal Docker hostnames.
ServiceUrls__ApiUrl=https://api.yourdomain.com
ServiceUrls__AuthUrl=https://auth.yourdomain.com
ServiceUrls__WebUrl=https://app.yourdomain.com

# Cookie domain — set to your root domain with leading dot for subdomain sharing
Authentication__CookieDomain=.yourdomain.com

# -----------------------------------------------------------------------------
# CORS (REQUIRED — must list all frontend origins)
# -----------------------------------------------------------------------------
# Add each allowed origin as a separate indexed entry.
# These should match your public-facing frontend URLs.
Cors__AllowedOrigins__0=https://app.yourdomain.com
Cors__AllowedOrigins__1=https://auth.yourdomain.com

# -----------------------------------------------------------------------------
# EMAIL / SMTP (REQUIRED for user registration, password reset, notifications)
# -----------------------------------------------------------------------------
# Examples: Amazon SES, Postmark, Mailgun, SendGrid, or your own SMTP server.
Smtp__Host=CHANGE_ME_SMTP_HOST
Smtp__Port=587
Smtp__UseSsl=true
Smtp__Username=CHANGE_ME_SMTP_USERNAME
Smtp__Password=CHANGE_ME_SMTP_PASSWORD
Smtp__DefaultFromAddress=noreply@yourdomain.com
Smtp__DefaultFromName=Wallow

# -----------------------------------------------------------------------------
# INITIAL ADMIN ACCOUNT (first run only — auto-creates the admin user)
# -----------------------------------------------------------------------------
# If set: Admin is created automatically on first startup. API is immediately
#          operational. These are ignored on subsequent startups.
# If empty: API enters "setup mode" and returns 503 for all requests until
#           you create an admin via POST /api/v1/identity/setup/admin.
#
# Recommendation: Always set these for production so the API boots ready.
AdminBootstrap__Email=admin@yourdomain.com
AdminBootstrap__Password=CHANGE_ME_USE_STRONG_PASSWORD
AdminBootstrap__FirstName=Admin
AdminBootstrap__LastName=User

# -----------------------------------------------------------------------------
# OIDC CLIENT: Wallow.Web Dashboard (REQUIRED)
# -----------------------------------------------------------------------------
# This registers the Web dashboard as an OIDC client of the API.
# The Secret must match what Wallow.Web is configured with.
PreRegisteredClients__Clients__0__ClientId=wallow-web-client
PreRegisteredClients__Clients__0__DisplayName=Wallow Web
PreRegisteredClients__Clients__0__Secret=CHANGE_ME_GENERATE_RANDOM_SECRET
PreRegisteredClients__Clients__0__TenantName=Default
PreRegisteredClients__Clients__0__RedirectUris__0=https://app.yourdomain.com/signin-oidc
PreRegisteredClients__Clients__0__PostLogoutRedirectUris__0=https://app.yourdomain.com/signout-callback-oidc
PreRegisteredClients__Clients__0__Scopes__0=openid
PreRegisteredClients__Clients__0__Scopes__1=email
PreRegisteredClients__Clients__0__Scopes__2=profile
PreRegisteredClients__Clients__0__Scopes__3=roles
PreRegisteredClients__Clients__0__Scopes__4=offline_access
PreRegisteredClients__Clients__0__SeedMembers__0=admin@yourdomain.com

# -----------------------------------------------------------------------------
# FILE STORAGE
# -----------------------------------------------------------------------------
# Options: "Local" (files on disk) or "S3" (S3-compatible: AWS, MinIO, etc.)
Storage__Provider=Local
Storage__Local__BasePath=/var/wallow/storage
Storage__Local__BaseUrl=https://api.yourdomain.com

# Uncomment and fill these if using S3:
# Storage__Provider=S3
# Storage__S3__Endpoint=https://s3.amazonaws.com
# Storage__S3__AccessKey=CHANGE_ME_AWS_ACCESS_KEY
# Storage__S3__SecretKey=CHANGE_ME_AWS_SECRET_KEY
# Storage__S3__BucketName=wallow-files
# Storage__S3__Region=us-east-1
# Storage__S3__UsePathStyle=false

# ClamAV antivirus scanning (optional — only if running ClamAV container)
# Storage__ClamAvHost=clamav
# Storage__ClamAvPort=3310

# -----------------------------------------------------------------------------
# EXTERNAL AUTH PROVIDERS (optional — uncomment to enable SSO)
# -----------------------------------------------------------------------------
# Google
# Authentication__Google__ClientId=
# Authentication__Google__ClientSecret=

# Microsoft / Entra ID
# Authentication__Microsoft__ClientId=
# Authentication__Microsoft__ClientSecret=

# GitHub
# Authentication__GitHub__ClientId=
# Authentication__GitHub__ClientSecret=

# Apple
# Authentication__Apple__ServiceId=
# Authentication__Apple__TeamId=
# Authentication__Apple__KeyId=
# Authentication__Apple__PrivateKeyPath=

# -----------------------------------------------------------------------------
# OBSERVABILITY (optional — OpenTelemetry)
# -----------------------------------------------------------------------------
# Set these if you're running a telemetry collector (Grafana Alloy, Jaeger, etc.)
# OpenTelemetry__EnableLogging=true
# OpenTelemetry__ServiceName=Wallow
# OpenTelemetry__OtlpEndpoint=http://alloy:4318
# OpenTelemetry__OtlpGrpcEndpoint=http://alloy:4317
# Observability__TraceSamplingRatio=0.1

# -----------------------------------------------------------------------------
# MODULE FEATURE FLAGS (all enabled by default — disable what you don't need)
# -----------------------------------------------------------------------------
# FeatureManagement__Modules.Billing=true
# FeatureManagement__Modules.Identity=true
# FeatureManagement__Modules.Storage=true
# FeatureManagement__Modules.Notifications=true
# FeatureManagement__Modules.Messaging=true
# FeatureManagement__Modules.Announcements=true
# FeatureManagement__Modules.Configuration=true
# FeatureManagement__Modules.Inquiries=true
# FeatureManagement__Modules.ApiKeys=false

# -----------------------------------------------------------------------------
# SIGNALR (optional — defaults are fine for most setups)
# -----------------------------------------------------------------------------
# SignalR__RedisPrefix=Wallow

# -----------------------------------------------------------------------------
# PLUGINS (optional)
# -----------------------------------------------------------------------------
# Plugins__PluginsDirectory=plugins/
# Plugins__AutoDiscover=true
# Plugins__AutoEnable=false
