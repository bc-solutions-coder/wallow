# Environment
COMPOSE_PROJECT_NAME=wallow-dev
ASPNETCORE_ENVIRONMENT=Development

# App Image
APP_IMAGE=ghcr.io/bc-solutions-coder/wallow
APP_TAG=dev

# PostgreSQL
POSTGRES_USER=wallow
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=wallow

# RabbitMQ
RABBITMQ_USER=wallow
RABBITMQ_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Email (Production only - Dev/Staging use Mailpit)
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
