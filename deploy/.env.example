# Environment
COMPOSE_PROJECT_NAME=wallow-dev
ASPNETCORE_ENVIRONMENT=Development

# App Image
APP_IMAGE=ghcr.io/bc-solutions-coder/wallow
APP_TAG=dev

# PostgreSQL
POSTGRES_USER=wallow
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=wallow

# Valkey (Redis-compatible cache)
VALKEY_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# JWT Signing Key (generate with: openssl rand -base64 48)
Identity__SigningKey=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# Email (Dev/Staging use Mailpit — no config needed)
# For production SMTP, see .env.production.example
