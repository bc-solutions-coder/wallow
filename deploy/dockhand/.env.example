# =============================================================================
# Wallow — wallow.dev Production Environment
# =============================================================================
# Copy to your server alongside docker-compose.yml.
# Lines marked CHANGE_ME must be updated before first run.
# Generate secrets: openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# PROJECT
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=wallow

# -----------------------------------------------------------------------------
# APP IMAGES (from GitHub Container Registry)
# -----------------------------------------------------------------------------
# To upgrade: change APP_TAG, then run: docker compose pull && docker compose up -d
APP_IMAGE=ghcr.io/bc-solutions-coder/wallow
APP_TAG=latest

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_USER=wallow
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=wallow

# -----------------------------------------------------------------------------
# VALKEY (Redis-compatible cache + SignalR backplane)
# -----------------------------------------------------------------------------
VALKEY_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# GARAGEHQ (S3-compatible object storage)
# -----------------------------------------------------------------------------
GARAGE_KEY_NAME=wallow-prod
GARAGE_ACCESS_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_12
GARAGE_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
GARAGE_BUCKET=wallow-files
# Generate: openssl rand -hex 32
GARAGE_RPC_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
GARAGE_ADMIN_TOKEN=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# SMTP (ZeptoMail)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=emailapikey
SMTP_PASSWORD=CHANGE_ME_ZEPTOMAIL_PASSWORD
SMTP_FROM_ADDRESS=noreply@wallow.dev
SMTP_FROM_NAME=Wallow

# -----------------------------------------------------------------------------
# JWT / SIGNING KEY (REQUIRED — app won't start without this)
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 48
Identity__SigningKey=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# -----------------------------------------------------------------------------
# INITIAL ADMIN ACCOUNT (created on first startup, ignored after)
# -----------------------------------------------------------------------------
AdminBootstrap__Email=CHANGE_ME_admin@wallow.dev
AdminBootstrap__Password=CHANGE_ME_USE_STRONG_PASSWORD
AdminBootstrap__FirstName=Admin
AdminBootstrap__LastName=User

# -----------------------------------------------------------------------------
# OIDC CLIENT: Wallow.Web (Dashboard)
# -----------------------------------------------------------------------------
# The Web app authenticates users via the API's OpenIddict server.
# The secret here must match what wallow-web is configured with.
OIDC_CLIENT_ID=wallow-web-client
OIDC_CLIENT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# This registers the OIDC client in the API on startup:
PreRegisteredClients__Clients__0__ClientId=wallow-web-client
PreRegisteredClients__Clients__0__DisplayName=Wallow Web
PreRegisteredClients__Clients__0__Secret=CHANGE_ME_SAME_AS_OIDC_CLIENT_SECRET_ABOVE
PreRegisteredClients__Clients__0__TenantName=Default
PreRegisteredClients__Clients__0__RedirectUris__0=https://wallow.dev/signin-oidc
PreRegisteredClients__Clients__0__PostLogoutRedirectUris__0=https://wallow.dev/signout-callback-oidc
PreRegisteredClients__Clients__0__Scopes__0=openid
PreRegisteredClients__Clients__0__Scopes__1=email
PreRegisteredClients__Clients__0__Scopes__2=profile
PreRegisteredClients__Clients__0__Scopes__3=roles
PreRegisteredClients__Clients__0__Scopes__4=offline_access
PreRegisteredClients__Clients__0__SeedMembers__0=CHANGE_ME_admin@wallow.dev

# -----------------------------------------------------------------------------
# PORTS (Pangolin routes to these internally)
# -----------------------------------------------------------------------------
# api.wallow.dev  -> localhost:8080
# auth.wallow.dev -> localhost:8081
# wallow.dev      -> localhost:8082
API_PORT=8080
AUTH_PORT=8081
WEB_PORT=8082

# -----------------------------------------------------------------------------
# GRAFANA (optional — enable observability profile)
# -----------------------------------------------------------------------------
# Start with: docker compose --profile observability up -d
# Access at: http://localhost:3001
GF_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
