{
  "name": "@bc-solutions-coder/wallow-web",
  "version": "0.0.0",
  "private": true,
  "description": "Wallow web frontend (TanStack Start + BFF SDK)",
  "type": "module",
  "scripts": {
    "dev": "tsx dev-server.ts",
    "build": "vite build && vite build --config vite.ssr.config.ts",
    "start": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:cross-app": "playwright test --config playwright.cross-app.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bc-solutions-coder/sdk": "workspace:*",
    "@bc-solutions-coder/styles": "workspace:*",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.28",
    "h3": "^1.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/router-plugin": "^1.168.20",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "playwright": "^1.61.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  }
}
