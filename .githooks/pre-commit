#!/bin/sh
# Pre-commit hook: verify C# code formatting
# Setup: git config core.hooksPath .githooks

# Check for staged .cs files
STAGED_CS=$(git diff --cached --name-only --diff-filter=ACM -- '*.cs')

if [ -z "$STAGED_CS" ]; then
    exit 0
fi

# Verify formatting on staged .cs files
echo "$STAGED_CS" | xargs dotnet format api/Wallow.slnx --verify-no-changes --verbosity quiet --include 2>/dev/null

if [ $? -ne 0 ]; then
    echo ""
    echo "Formatting issues found in staged .cs files."
    echo "Run 'dotnet format' to fix them, then re-stage and commit."
    exit 1
fi
