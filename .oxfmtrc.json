{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "semi": true,
  "trailingComma": "all",
  "ignorePatterns": [
    "**/dist/**",
    "**/generated/**",
    "**/routeTree.gen.ts",
    "packages/sdk/src/generated/**",
    "packages/sdk/openapi/**"
  ]
}
