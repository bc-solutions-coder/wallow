      "name": "invoices.read",
      "description": "Read access to invoices",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "invoices.write",
      "description": "Write access to invoices",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "payments.read",
      "description": "Read access to payments",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
