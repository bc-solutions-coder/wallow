      }
    },
    {
      "name": "payments.write",
      "description": "Write access to payments",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "subscriptions.read",
      "description": "Read access to subscriptions",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "subscriptions.write",
      "description": "Write access to subscriptions",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "users.read",
      "description": "Read access to users",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "users.write",
      "description": "Write access to users",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "notifications.read",
      "description": "Read access to notifications",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "notifications.write",
      "description": "Write access to notifications",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "catalog.read",
      "description": "Read access to catalog items",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "catalog.write",
      "description": "Write access to catalog items",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "orders.read",
      "description": "Read access to orders",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "orders.write",
      "description": "Write access to orders",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "webhooks.manage",
      "description": "Manage webhook subscriptions",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "tenant-context",
      "description": "Adds tenant_id claim from client attributes",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-client-attribute-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_id",
            "client.attribute": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "verifyEmail": false,
  "bruteForceProtected": true,
  "maxFailureWaitSeconds": 900,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "sslRequired": "external",
  "organizationsEnabled": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespanForImplicitFlow": 900,
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@foundry.dev",
    "fromDisplayName": "Foundry",
    "replyTo": "",
    "replyToDisplayName": "",
    "envelopeFrom": "",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full platform access - can manage all users, organizations, and settings",
        "composite": false
      },
      {
        "name": "manager",
        "description": "Team/project management access - can manage team members and projects",
        "composite": false
      },
      {
        "name": "user",
        "description": "Standard user access - can manage own tasks and view assigned projects",
        "composite": false
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-foundry",
    "composites": {
      "realm": [
        "user"
      ]
    }
  },
  "clients": [
    {
      "clientId": "foundry-api",
      "name": "Foundry API",
      "description": "Backend API - validates tokens and calls Admin API via service account",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "foundry-api-secret",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "authorizationServicesEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [],
      "webOrigins": [],
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-client-attribute-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_id",
            "client.attribute": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "foundry-spa",
      "name": "Foundry SPA",
      "description": "Frontend SPA - Authorization Code flow with PKCE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:4200",
        "+"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*##http://localhost:4200/*"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@foundry.dev",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Admin123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "default-roles-foundry"
      ]
    },
    {
      "username": "service-account-foundry-api",
      "enabled": true,
      "serviceAccountClientId": "foundry-api",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users"
        ]
      }
    }
  ],
  "scopeMappings": [
    {
      "client": "foundry-api",
      "roles": [
        "admin",
        "manager",
        "user"
      ]
    }
  ],
  "clientScopeMappings": {
    "realm-management": [
      {
        "client": "foundry-api",
        "roles": [
          "manage-users",
          "view-users"
        ]
      }
    ]
  }
}
