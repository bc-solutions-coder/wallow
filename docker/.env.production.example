# =============================================================================
# Wallow Production Environment
# =============================================================================
# Copy to .env.production and update values before running:
#
#   cd docker
#   cp .env.production.example .env.production
#   # Edit .env.production — replace every CHANGE_ME value
#   docker compose -f docker-compose.production.yml --env-file .env.production up --build
#
# Generate secrets:
#   openssl rand -base64 32   # general passwords / signing keys
#   openssl rand -hex 12      # Garage access key ID (24 hex chars)
#   openssl rand -hex 32      # Garage secret key / RPC secret
# =============================================================================

# -----------------------------------------------------------------------------
# PROJECT
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=wallow

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_USER=wallow
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=wallow

# -----------------------------------------------------------------------------
# VALKEY (Redis-compatible cache + SignalR backplane)
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
VALKEY_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# GARAGEHQ (S3-compatible object storage)
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
GARAGE_RPC_SECRET=CHANGE_ME
# Generate: openssl rand -base64 32
GARAGE_ADMIN_TOKEN=CHANGE_ME
# Generate: openssl rand -hex 12  (must be exactly 24 hex chars)
GARAGE_ACCESS_KEY=CHANGE_ME
# Generate: openssl rand -hex 32  (must be exactly 64 hex chars)
GARAGE_SECRET_KEY=CHANGE_ME
GARAGE_KEY_NAME=wallow
GARAGE_BUCKET=wallow-files
GARAGE_REGION=us-east-1
GARAGE_S3_PORT=3900
GARAGE_ADMIN_PORT=3903

# -----------------------------------------------------------------------------
# SMTP
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=emailapikey
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_ADDRESS=noreply@wallow.dev
SMTP_FROM_NAME=Wallow

# -----------------------------------------------------------------------------
# IDENTITY / JWT SIGNING KEY
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 48
IDENTITY_SIGNING_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# OPENIDDICT CERTIFICATES
# These passwords protect the .pfx files generated on first API startup.
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
OPENIDDICT_SIGNING_CERT_PASSWORD=CHANGE_ME
OPENIDDICT_ENCRYPTION_CERT_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# ADMIN BOOTSTRAP (created on first startup, ignored after)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@wallow.dev
# Generate: choose a strong password (min 12 chars, mixed case + symbols)
ADMIN_PASSWORD=CHANGE_ME
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# -----------------------------------------------------------------------------
# OIDC CLIENT: Wallow.Web (Dashboard)
# The client secret here must match what wallow-web is configured with.
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
OIDC_CLIENT_ID=wallow-web-client
OIDC_CLIENT_SECRET=CHANGE_ME

# -----------------------------------------------------------------------------
# OIDC CLIENT: Additional clients (optional)
# Add additional pre-registered OIDC clients here.
# Generate secret: openssl rand -base64 32
# -----------------------------------------------------------------------------
# BCORDES_CLIENT_ID=bcordes-client
# BCORDES_CLIENT_SECRET=CHANGE_ME
# BCORDES_TENANT_NAME=Bcordes
# BCORDES_ADMIN_EMAIL=admin@bcordes.dev
# BCORDES_PUBLIC_URL=https://bcordes.dev

# -----------------------------------------------------------------------------
# PUBLIC URLS (what browsers see — used for OIDC, CORS, redirects)
# Path-based routing: all services live under wallow.dev
#   wallow.dev/api  -> API
#   wallow.dev/auth -> Auth
#   wallow.dev      -> Web (dashboard)
# For local testing, use http://localhost:PORT values.
# -----------------------------------------------------------------------------
API_PUBLIC_URL=https://wallow.dev/api
AUTH_PUBLIC_URL=https://wallow.dev/auth
WEB_PUBLIC_URL=https://wallow.dev
# Cookie domain — all services share the same domain now.
# For local testing, use: localhost
COOKIE_DOMAIN=wallow.dev

# -----------------------------------------------------------------------------
# PORTS (host port mapping — reverse proxy routes to these)
# wallow.dev/api  -> localhost:8080
# wallow.dev/auth -> localhost:8081
# wallow.dev      -> localhost:8082
# -----------------------------------------------------------------------------
API_PORT=8080
AUTH_PORT=8081
WEB_PORT=8082

# -----------------------------------------------------------------------------
# GRAFANA (optional — enable with: --profile observability)
# Access at: http://localhost:3001
# Generate: openssl rand -base64 24
# -----------------------------------------------------------------------------
GF_ADMIN_PASSWORD=CHANGE_ME
