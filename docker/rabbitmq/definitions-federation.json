{
  "parameters": [
    {
      "value": {
        "uri": "amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq-replica:5672",
        "prefetch-count": 1000,
        "reconnect-delay": 5,
        "ack-mode": "on-confirm",
        "trust-user-id": false,
        "exchange": "",
        "queue": ""
      },
      "vhost": "/",
      "component": "federation-upstream",
      "name": "replica-upstream"
    }
  ],
  "policies": [
    {
      "vhost": "/",
      "name": "federate-events",
      "pattern": "^wallow\\.events\\.",
      "apply-to": "exchanges",
      "definition": {
        "federation-upstream-set": "all"
      },
      "priority": 0
    },
    {
      "vhost": "/",
      "name": "federate-queues",
      "pattern": "^wallow\\.federated\\.",
      "apply-to": "queues",
      "definition": {
        "federation-upstream-set": "all"
      },
      "priority": 0
    }
  ]
}
