# Environment Configuration
# Copy to .env and modify for your environment

# Project
COMPOSE_PROJECT_NAME=wallow

# PostgreSQL
POSTGRES_USER=wallow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wallow

# Email (Production only - Dev/Staging use MailHog)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Valkey
VALKEY_PASSWORD=changeme

# GarageHQ (S3-compatible object storage)
GARAGE_KEY_NAME=wallow-dev
GARAGE_ACCESS_KEY=changeme
GARAGE_SECRET_KEY=changeme
GARAGE_BUCKET=wallow-files

# Grafana
GF_ADMIN_PASSWORD=changeme
