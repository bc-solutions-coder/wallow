{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Modules/*/*.Domain/*.csproj",
            "src/Modules/*/*.Application/*.csproj",
            "src/Modules/*/*.Api/*.csproj",
            "src/Shared/**/*.csproj",
            "src/Wallow.Api/*.csproj"
          ],
          "exclude": [
            "src/Modules/*/*.Infrastructure/*.csproj"
          ]
        }
      ],
      "dest": ".docfx/api",
      "filter": "docfx/filterConfig.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.md", "toc.yml"],
        "src": "docs",
        "dest": "."
      },
      {
        "files": ["toc.yml"],
        "src": "docfx"
      },
      {
        "files": [".docfx/api/**.yml", ".docfx/api/index.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "globalMetadata": {
      "_appTitle": "Wallow",
      "_appFooter": "Wallow Platform",
      "_enableSearch": true,
      "_description": "Wallow is a .NET 10 modular monolith starter platform with multi-tenancy, Clean Architecture, DDD, CQRS, and Wolverine messaging.",
      "_ogImage": "https://raw.githubusercontent.com/bc-solutions-coder/wallow/main/assets/social-preview.png",
      "_ogType": "website"
    },
    "template": ["default", "modern", "docfx/templates/wallow"],
    "dest": ".docfx/_site"
  }
}
