{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Wolverine": "Warning",
        "JasperFx.CodeGeneration": "Warning",
        "System.Net.Http": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "AuthUrl": "",
  "DocsUrl": "https://docs.wallow.dev",
  "Authentication": {
    "CookieDomain": ".wallow.dev"
  },
  "ModuleMessaging": {
    "Transport": "InMemory"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=wallow;Username=wallow;Password=SET_VIA_ConnectionStrings__DefaultConnection_OR_USER_SECRETS;SSL Mode=Require;Trust Server Certificate=false",
    "ReadReplicaConnection": "Host=localhost;Port=5432;Database=wallow;Username=wallow;Password=SET_VIA_ConnectionStrings__ReadReplicaConnection_OR_USER_SECRETS;SSL Mode=Require;Trust Server Certificate=false",
    "Redis": "localhost:6379,password=,abortConnect=false"
  },
  "ServiceUrls": {
    "ApiUrl": "",
    "AuthUrl": "",
    "WebUrl": ""
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "http://localhost:5173"]
  },
  "Notifications": {
    "Email": {
      "Provider": "Smtp"
    }
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "UseSsl": false,
    "Username": "",
    "Password": "",
    "DefaultFromAddress": "noreply@wallow.local",
    "DefaultFromName": "Wallow",
    "MaxRetries": 3,
    "TimeoutSeconds": 30
  },
  "OpenTelemetry": {
    "EnableLogging": false,
    "ServiceName": "Wallow",
    "OtlpEndpoint": "http://localhost:4318",
    "OtlpGrpcEndpoint": "http://localhost:4317"
  },
  "Storage": {
    "Provider": "S3",
    "Local": {
      "BasePath": "/var/wallow/storage",
      "BaseUrl": "http://localhost:5001"
    },
    "S3": {
      "Endpoint": "http://localhost:3900",
      "AccessKey": "SET_VIA_Storage__S3__AccessKey",
      "SecretKey": "SET_VIA_Storage__S3__SecretKey",
      "BucketName": "wallow-files",
      "UsePathStyle": true,
      "Region": "us-east-1"
    }
  },
  "Identity": {
    "SigningKey": "REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"
  },
  "FeatureManagement": {
    "Modules.Billing": true,
    "Modules.Branding": true,
    "Modules.Identity": true,
    "Modules.Storage": true,
    "Modules.Notifications": true,
    "Modules.Messaging": true,
    "Modules.Announcements": true,
    "Modules.Configuration": true,
    "Modules.Inquiries": true,
    "Modules.ApiKeys": false
  },
  "Wallow": {
    "Modules": {
      "Identity": true,
      "Billing": true,
      "Notifications": true,
      "Messaging": true,
      "Announcements": true,
      "Storage": true,
      "Configuration": true,
      "Inquiries": true,
      "ApiKeys": false
    }
  },
  "Database": {
    "MaxPoolSize": 200,
    "MinPoolSize": 10
  },
  "ApiKeys": {
    "MaxPerUser": 10
  },
  "AdminBootstrap": {
    "Email": "",
    "Password": "",
    "FirstName": "",
    "LastName": ""
  },
  "PreRegisteredClients": {
    "Clients": []
  },
  "Plugins": {
    "PluginsDirectory": "plugins/",
    "AutoDiscover": true,
    "AutoEnable": false,
    "Permissions": {}
  },
  "Performance": {
    "ThreadPoolMinWorkerThreads": 0,
    "ThreadPoolMinCompletionPortThreads": 0,
    "KestrelMaxConcurrentConnections": null,
    "KestrelMaxConcurrentUpgradedConnections": null
  }
}
