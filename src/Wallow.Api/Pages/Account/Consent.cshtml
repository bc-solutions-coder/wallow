@page
@model Wallow.Api.Pages.Account.ConsentModel

<h2>Authorize @Model.ApplicationName</h2>

<p>The application <strong>@Model.ApplicationName</strong> is requesting access to the following:</p>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <p style="color:red;">@Model.ErrorMessage</p>
}

<ul>
    @foreach (var scope in Model.RequestedScopes)
    {
        <li><strong>@scope.DisplayName</strong> &mdash; @scope.Description</li>
    }
</ul>

<form method="post">
    <div style="margin-top:12px;">
        <button type="submit" asp-page-handler="Grant">Allow</button>
        <button type="submit" asp-page-handler="Deny" style="margin-left:8px;">Deny</button>
    </div>
</form>
