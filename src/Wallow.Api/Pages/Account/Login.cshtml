@page
@model Wallow.Api.Pages.Account.LoginModel

<h2>Sign In</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <p style="color:red;">@Model.ErrorMessage</p>
}

<form method="post">
    <div>
        <label for="Input_Email">Email</label><br />
        <input type="email" id="Input_Email" asp-for="Input.Email" required />
    </div>
    <div style="margin-top:8px;">
        <label for="Input_Password">Password</label><br />
        <input type="password" id="Input_Password" asp-for="Input.Password" required />
    </div>
    <div style="margin-top:12px;">
        <button type="submit">Sign In</button>
    </div>
    <input type="hidden" asp-for="ReturnUrl" />
</form>
