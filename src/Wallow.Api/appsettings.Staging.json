{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=wallow;Username=OVERRIDE_VIA_ENV_VAR;Password=OVERRIDE_VIA_ENV_VAR",
    "ReadReplicaConnection": "Host=postgres-replica;Database=wallow;Username=OVERRIDE_VIA_ENV_VAR;Password=OVERRIDE_VIA_ENV_VAR"
  },
  "Smtp": {
    "Host": "mailpit",
    "Port": 1025,
    "UseSsl": false,
    "DefaultFromAddress": "noreply@wallow.staging",
    "DefaultFromName": "Wallow Staging"
  },
  "Cors": {
    "_corsNote": "AllowedOrigins must be set via environment variables (e.g. Cors__AllowedOrigins__0=https://app.yourdomain.com) before deployment",
    "AllowedOrigins": []
  },
  "Storage": {
    "Provider": "S3",
    "S3": {
      "Endpoint": "http://garage:3900",
      "AccessKey": "OVERRIDE_VIA_ENV_VAR",
      "SecretKey": "OVERRIDE_VIA_ENV_VAR",
      "BucketName": "wallow-files",
      "UsePathStyle": true,
      "Region": "us-east-1"
    }
  },
  "Elsa": {
    "Identity": {
      "SigningKey": "OVERRIDE_VIA_ENV_VAR"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "Wallow",
    "OtlpEndpoint": "http://localhost:4318"
  },
  "Performance": {
    "ThreadPoolMinWorkerThreads": 200,
    "ThreadPoolMinCompletionPortThreads": 200,
    "KestrelMaxConcurrentConnections": 5000,
    "KestrelMaxConcurrentUpgradedConnections": 1000
  }
}
