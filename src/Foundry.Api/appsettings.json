{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Wolverine": "Warning",
        "System.Net.Http": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ModuleMessaging": {
    "Transport": "InMemory"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=foundry;Username=foundry;Password=SET_VIA_ConnectionStrings__DefaultConnection_OR_USER_SECRETS;SSL Mode=Require;Trust Server Certificate=false",
    "Redis": "localhost:6379,password=,abortConnect=false",
    "RabbitMq": "amqps://SET_VIA_ConnectionStrings__RabbitMq_OR_USER_SECRETS@localhost:5671"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5671,
    "Username": "SET_VIA_RabbitMQ__Username",
    "Password": "SET_VIA_RabbitMQ__Password"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "http://localhost:5173"]
  },
  "Notifications": {
    "Email": {
      "Provider": "Smtp"
    }
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "UseSsl": false,
    "Username": "",
    "Password": "",
    "DefaultFromAddress": "noreply@foundry.local",
    "DefaultFromName": "Foundry",
    "MaxRetries": 3,
    "TimeoutSeconds": 30
  },
  "OpenTelemetry": {
    "EnableLogging": false,
    "ServiceName": "Foundry",
    "OtlpEndpoint": "http://localhost:4318",
    "OtlpGrpcEndpoint": "http://localhost:4317"
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "BasePath": "/var/foundry/storage",
      "BaseUrl": "http://localhost:5000"
    },
    "S3": {
      "Endpoint": "http://localhost:9000",
      "AccessKey": "SET_VIA_Storage__S3__AccessKey",
      "SecretKey": "SET_VIA_Storage__S3__SecretKey",
      "BucketName": "foundry-files",
      "UsePathStyle": true,
      "Region": "us-east-1"
    }
  },
  "Keycloak": {
    "realm": "foundry",
    "auth-server-url": "https://keycloak.yourdomain.com/",
    "ssl-required": "external",
    "resource": "foundry-api",
    "credentials": {
      "secret": "REPLACE_IN_PRODUCTION"
    },
    "verify-token-audience": true,
    "confidential-port": 0
  },
  "KeycloakAdmin": {
    "realm": "foundry",
    "auth-server-url": "https://keycloak.yourdomain.com/",
    "resource": "foundry-api",
    "credentials": {
      "secret": "REPLACE_IN_PRODUCTION"
    }
  },
  "Identity": {
    "Keycloak": {
      "Realm": "foundry",
      "AuthorityUrl": "http://localhost:8080/",
      "AdminClientId": "foundry-api",
      "AdminClientSecret": "REPLACE_IN_PRODUCTION"
    }
  },
  "FeatureManagement": {
    "Modules.Billing": true,
    "Modules.Identity": true,
    "Modules.Storage": true,
    "Modules.Notifications": true,
    "Modules.Messaging": true,
    "Modules.Announcements": true,
    "Modules.Configuration": true,
    "Modules.Inquiries": false,
    "Modules.Showcases": false
  },
  "Foundry": {
    "Modules": {
      "Identity": true,
      "Billing": true,
      "Notifications": true,
      "Messaging": true,
      "Announcements": true,
      "Storage": true,
      "Configuration": true,
      "Inquiries": false,
      "Showcases": false
    }
  },
  "Plugins": {
    "PluginsDirectory": "plugins/",
    "AutoDiscover": true,
    "AutoEnable": false,
    "Permissions": {}
  }
}
