@page "/dashboard/organizations/{OrgId:guid}"
@layout DashboardLayout
@attribute [Authorize]
@rendermode InteractiveServer
@using Wallow.Web.Models
@using Wallow.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IOrganizationApiService OrganizationService
@inject IAppRegistrationService AppService

<div class="max-w-5xl mx-auto">
    <a href="/dashboard/organizations" class="text-sm text-[#d4a017] hover:text-[#b8880f] no-underline mb-4 inline-block">
        &larr; Back to Organizations
    </a>

    @if (_loading)
    {
        <div class="text-[#3d2b1f]/60 text-center py-12">Loading organization...</div>
    }
    else if (_organization is null)
    {
        <div class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] p-12 text-center">
            <h2 class="text-xl font-semibold text-[#3d2b1f] mb-2">Organization not found</h2>
            <p class="text-[#3d2b1f]/60 mb-6">The organization you're looking for doesn't exist or you don't have access.</p>
            <a href="/dashboard/organizations"
               class="bg-[#d4a017] text-white font-medium px-6 py-2.5 rounded-full hover:bg-[#b8880f] no-underline text-sm transition-colors">
                View Organizations
            </a>
        </div>
    }
    else
    {
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-[#3d2b1f]">@_organization.Name</h1>
            <div class="flex gap-6 mt-2 text-sm text-[#3d2b1f]/70">
                <span>Domain: <span class="font-mono">@(_organization.Domain ?? "---")</span></span>
                <span>Members: <span class="font-semibold">@_organization.MemberCount</span></span>
            </div>
        </div>

        <!-- Members -->
        <div class="mb-8">
            <h2 class="text-xl font-semibold text-[#3d2b1f] mb-4">Members</h2>
            @if (_members is null || _members.Count == 0)
            {
                <div class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] p-8 text-center text-[#3d2b1f]/60">
                    No members found.
                </div>
            }
            else
            {
                <div class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-[#faf6f1] border-b border-[#e8d5b7]">
                            <tr>
                                <th class="px-6 py-3 text-xs font-semibold text-[#3d2b1f]/70 uppercase tracking-wider">Email</th>
                                <th class="px-6 py-3 text-xs font-semibold text-[#3d2b1f]/70 uppercase tracking-wider">Role</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#e8d5b7]">
                            @foreach (OrganizationMemberModel member in _members)
                            {
                                <tr class="hover:bg-[#faf6f1]/50">
                                    <td class="px-6 py-4 text-sm font-medium text-[#3d2b1f]">@member.Email</td>
                                    <td class="px-6 py-4">
                                        @foreach (string role in member.Roles)
                                        {
                                            <span class="inline-block bg-[#e8d5b7] text-[#3d2b1f] text-xs font-medium px-2.5 py-0.5 rounded-full mr-1">
                                                @role
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Bound Clients -->
        <div class="mb-8">
            <h2 class="text-xl font-semibold text-[#3d2b1f] mb-4">Bound Clients</h2>
            @if (_clients is null || _clients.Count == 0)
            {
                <div class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] p-8 text-center text-[#3d2b1f]/60">
                    No clients bound to this organization.
                </div>
            }
            else
            {
                <div class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-[#faf6f1] border-b border-[#e8d5b7]">
                            <tr>
                                <th class="px-6 py-3 text-xs font-semibold text-[#3d2b1f]/70 uppercase tracking-wider">Client ID</th>
                                <th class="px-6 py-3 text-xs font-semibold text-[#3d2b1f]/70 uppercase tracking-wider">Name</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#e8d5b7]">
                            @foreach (ClientModel client in _clients)
                            {
                                <tr class="hover:bg-[#faf6f1]/50">
                                    <td class="px-6 py-4 text-sm text-[#3d2b1f]/70 font-mono">@client.ClientId</td>
                                    <td class="px-6 py-4 text-sm font-medium text-[#3d2b1f]">@client.Name</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Register Client Form -->
        <div class="mb-8">
            <h2 class="text-xl font-semibold text-[#3d2b1f] mb-4">Register Client</h2>
            <div class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] p-8">
                @if (_registerResult is { Success: true })
                {
                    <div class="bg-green-50 border border-green-300 rounded-md p-4 mb-6">
                        <p class="text-green-800 text-sm font-semibold">Client registered successfully.</p>
                        @if (!string.IsNullOrEmpty(_registerResult.ClientId))
                        {
                            <p class="text-green-800 text-sm mt-1">Client ID: <code class="font-mono">@_registerResult.ClientId</code></p>
                        }
                        @if (!string.IsNullOrEmpty(_registerResult.ClientSecret))
                        {
                            <p class="text-amber-800 text-sm font-semibold mt-2">Save your client secret now. It will not be shown again.</p>
                            <code class="block bg-white border border-amber-300 rounded-md px-4 py-2 text-sm font-mono text-[#3d2b1f] break-all mt-1">@_registerResult.ClientSecret</code>
                        }
                    </div>
                }
                else if (_registerResult is { Success: false })
                {
                    <div class="bg-red-50 border border-red-300 rounded-md p-4 mb-6">
                        <p class="text-red-800 text-sm">@_registerResult.ErrorMessage</p>
                    </div>
                }

                <EditForm Model="_registerForm" OnValidSubmit="HandleRegisterClient" FormName="register-client">
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Tenant ID</label>
                            <input type="text" value="@OrgId" readonly
                                   class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f]/50 bg-[#f5f0ea] font-mono cursor-not-allowed" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">App Name</label>
                            <InputText @bind-Value="_registerForm.DisplayName"
                                       class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent"
                                       placeholder="My Application" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Client Type</label>
                            <InputSelect @bind-Value="_registerForm.ClientType"
                                         class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent">
                                <option value="public">Public (SPA, mobile, desktop)</option>
                                <option value="confidential">Confidential (server-side)</option>
                            </InputSelect>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Redirect URIs</label>
                            <InputTextArea @bind-Value="_registerForm.RedirectUris"
                                           rows="3"
                                           class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent"
                                           placeholder="https://myapp.com/callback&#10;https://localhost:3000/callback" />
                            <p class="text-xs text-[#3d2b1f]/50 mt-1">One URI per line</p>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-3">Scopes</label>
                            <div class="flex flex-wrap gap-2">
                                @foreach (string scope in _availableScopes)
                                {
                                    bool isSelected = _registerForm.SelectedScopes.Contains(scope);
                                    <button type="button"
                                            @onclick="() => ToggleScope(scope)"
                                            class="@(isSelected
                                                ? "bg-[#d4a017] text-white"
                                                : "bg-[#faf6f1] text-[#3d2b1f] border border-[#e8d5b7]") px-4 py-1.5 rounded-full text-sm font-medium transition-colors hover:opacity-80">
                                        @scope
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="pt-2">
                            <button type="submit"
                                    disabled="@_submitting"
                                    class="w-full bg-[#d4a017] text-white font-medium px-6 py-3 rounded-full hover:bg-[#b8880f] disabled:opacity-50 transition-colors text-sm">
                                @(_submitting ? "Registering..." : "Register Client")
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid OrgId { get; set; }

    private OrganizationModel? _organization;
    private List<OrganizationMemberModel>? _members;
    private List<ClientModel>? _clients;
    private bool _loading = true;

    private readonly RegisterClientForm _registerForm = new();
    private RegisterAppResult? _registerResult;
    private bool _submitting;
    private readonly string[] _availableScopes = ["inquiries.read", "inquiries.write", "announcements.read", "storage.read"];

    protected override async Task OnInitializedAsync()
    {
        _organization = await OrganizationService.GetOrganizationAsync(OrgId);
        _members = await OrganizationService.GetMembersAsync(OrgId);
        _clients = await OrganizationService.GetClientsByTenantAsync(OrgId);
        _loading = false;
    }

    private void ToggleScope(string scope)
    {
        if (_registerForm.SelectedScopes.Contains(scope))
            _registerForm.SelectedScopes.Remove(scope);
        else
            _registerForm.SelectedScopes.Add(scope);
    }

    private async Task HandleRegisterClient()
    {
        _submitting = true;
        _registerResult = null;

        List<string> redirectUris = (_registerForm.RedirectUris ?? "")
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        RegisterAppModel model = new(
            _registerForm.DisplayName ?? "",
            _registerForm.ClientType ?? "public",
            redirectUris,
            _registerForm.SelectedScopes);

        _registerResult = await AppService.RegisterAppAsync(model);

        if (_registerResult is { Success: true })
        {
            _clients = await OrganizationService.GetClientsByTenantAsync(OrgId);
        }

        _submitting = false;
    }

    private sealed class RegisterClientForm
    {
        public string? DisplayName { get; set; }
        public string? ClientType { get; set; } = "public";
        public string? RedirectUris { get; set; }
        public List<string> SelectedScopes { get; set; } = ["inquiries.read"];
    }
}
