@page "/dashboard/organizations"
@layout DashboardLayout
@attribute [Authorize]
@rendermode InteractiveServer
@using Wallow.Web.Models
@using Wallow.Web.Services
@inject IOrganizationApiService OrganizationService

<div class="max-w-5xl mx-auto">
    <div class="flex items-center justify-between mb-8">
        <h1 data-testid="organizations-heading" class="text-3xl font-bold text-[#3d2b1f]">Organizations</h1>
        <a data-testid="organizations-create-link" href="/dashboard/organizations/create"
           class="bg-[#d4a017] text-white font-medium px-6 py-2.5 rounded-full hover:bg-[#b8880f] no-underline text-sm transition-colors">
            Create Organization
        </a>
    </div>

    @if (_loading)
    {
        <div class="text-[#3d2b1f]/60 text-center py-12">Loading organizations...</div>
    }
    else if (_organizations is null || _organizations.Count == 0)
    {
        <div data-testid="organizations-empty-state" class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] p-12 text-center">
            <div class="text-[80px] leading-none mb-4">🏢</div>
            <h2 class="text-xl font-semibold text-[#3d2b1f] mb-2">No organizations yet</h2>
            <p class="text-[#3d2b1f]/60 mb-6">You don't belong to any organizations. Get started by creating your first one.</p>
            <a href="/dashboard/organizations/create"
               class="bg-[#d4a017] text-white font-medium px-6 py-2.5 rounded-full hover:bg-[#b8880f] no-underline text-sm transition-colors">
                Create your first organization
            </a>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] overflow-hidden">
            <table data-testid="organizations-table" class="w-full text-left">
                <thead class="bg-[#faf6f1] border-b border-[#e8d5b7]">
                    <tr>
                        <th class="px-6 py-3 text-xs font-semibold text-[#3d2b1f]/70 uppercase tracking-wider">Name</th>
                        <th class="px-6 py-3 text-xs font-semibold text-[#3d2b1f]/70 uppercase tracking-wider">Domain</th>
                        <th class="px-6 py-3 text-xs font-semibold text-[#3d2b1f]/70 uppercase tracking-wider">Members</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#e8d5b7]">
                    @foreach (OrganizationModel org in _organizations)
                    {
                        <tr data-testid="organizations-row" class="hover:bg-[#faf6f1]/50">
                            <td class="px-6 py-4 text-sm font-medium text-[#3d2b1f]">
                                <a data-testid="organizations-row-link" href="/dashboard/organizations/@org.Id" class="text-[#3d2b1f] hover:text-[#d4a017] no-underline">@org.Name</a>
                            </td>
                            <td class="px-6 py-4 text-sm text-[#3d2b1f]/70 font-mono">@(org.Domain ?? "—")</td>
                            <td class="px-6 py-4">
                                <span class="inline-block bg-[#e8d5b7] text-[#3d2b1f] text-xs font-medium px-2.5 py-0.5 rounded-full">
                                    @org.MemberCount
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<OrganizationModel>? _organizations;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _organizations = await OrganizationService.GetOrganizationsAsync();
        _loading = false;
    }
}
