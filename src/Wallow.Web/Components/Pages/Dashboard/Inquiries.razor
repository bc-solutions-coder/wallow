@page "/dashboard/inquiries"
@layout DashboardLayout
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Wallow.Shared.Kernel.Extensions
@using Wallow.Web.Models
@using Wallow.Web.Services
@inject IInquiryService InquiryService
@inject AuthenticationStateProvider AuthStateProvider

<div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold text-[#3d2b1f] mb-8">Submit an Inquiry</h1>

    @if (_submitted)
    {
        <div data-testid="inquiry-success" class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] p-8 text-center">
            <div class="text-[48px] leading-none mb-2">🐷</div>
            <h2 class="text-xl font-semibold text-[#3d2b1f] mb-2">Inquiry Submitted</h2>
            <p class="text-[#3d2b1f]/60 mb-6">Thank you! We'll get back to you shortly.</p>
            <button @onclick="Reset"
                    class="bg-[#d4a017] text-white font-medium px-6 py-2.5 rounded-full hover:bg-[#b8880f] text-sm transition-colors">
                Submit Another
            </button>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow-sm border border-[#e8d5b7] p-8">
            @if (_errorMessage is not null)
            {
                <div data-testid="inquiry-error" class="bg-red-50 border border-red-300 rounded-md p-4 mb-6">
                    <p class="text-red-800 text-sm">@_errorMessage</p>
                </div>
            }

            <EditForm Model="_form" OnValidSubmit="HandleSubmit" FormName="inquiry">
                <div class="space-y-5">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Name</label>
                            <InputText @bind-Value="_form.Name"
                                       data-testid="inquiry-name"
                                       class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Email</label>
                            <InputText @bind-Value="_form.Email"
                                       data-testid="inquiry-email"
                                       class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent" />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Phone</label>
                            <InputText @bind-Value="_form.Phone"
                                       data-testid="inquiry-phone"
                                       class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent"
                                       placeholder="Optional" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Company</label>
                            <InputText @bind-Value="_form.Company"
                                       data-testid="inquiry-company"
                                       class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent"
                                       placeholder="Optional" />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Project Type</label>
                            <InputSelect @bind-Value="_form.ProjectType"
                                         data-testid="inquiry-project-type"
                                         class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent">
                                <option value="">Select...</option>
                                <option value="web-app">Web Application</option>
                                <option value="mobile-app">Mobile Application</option>
                                <option value="api">API / Backend</option>
                                <option value="saas">SaaS Platform</option>
                                <option value="consulting">Consulting</option>
                                <option value="other">Other</option>
                            </InputSelect>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Budget Range</label>
                            <InputSelect @bind-Value="_form.BudgetRange"
                                         data-testid="inquiry-budget-range"
                                         class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent">
                                <option value="">Select...</option>
                                <option value="under-5k">Under $5,000</option>
                                <option value="5k-15k">$5,000 - $15,000</option>
                                <option value="15k-50k">$15,000 - $50,000</option>
                                <option value="50k-100k">$50,000 - $100,000</option>
                                <option value="over-100k">$100,000+</option>
                            </InputSelect>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Timeline</label>
                            <InputSelect @bind-Value="_form.Timeline"
                                         data-testid="inquiry-timeline"
                                         class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent">
                                <option value="">Select...</option>
                                <option value="asap">ASAP</option>
                                <option value="1-3-months">1 - 3 months</option>
                                <option value="3-6-months">3 - 6 months</option>
                                <option value="6-plus-months">6+ months</option>
                                <option value="flexible">Flexible</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-[#3d2b1f] mb-1">Message</label>
                        <InputTextArea @bind-Value="_form.Message"
                                       data-testid="inquiry-message"
                                       rows="5"
                                       class="w-full border border-[#e8d5b7] rounded-md px-4 py-2 text-sm text-[#3d2b1f] bg-[#faf6f1] focus:outline-none focus:ring-2 focus:ring-[#d4a017] focus:border-transparent"
                                       placeholder="Tell us about your project..." />
                    </div>

                    <div class="pt-2">
                        <button type="submit"
                                data-testid="inquiry-submit"
                                disabled="@_submitting"
                                class="w-full bg-[#d4a017] text-white font-medium px-6 py-3 rounded-full hover:bg-[#b8880f] disabled:opacity-50 transition-colors text-sm">
                            @(_submitting ? "Submitting..." : "Submit Inquiry")
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private readonly InquiryForm _form = new();
    private bool _submitting;
    private bool _submitted;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();
        ClaimsPrincipal user = authState.User;

        _form.Name = user.GetDisplayName() ?? "";
        _form.Email = user.GetEmail() ?? "";
    }

    private async Task HandleSubmit()
    {
        _submitting = true;
        _errorMessage = null;

        InquiryModel model = new(
            _form.Name ?? "",
            _form.Email ?? "",
            _form.Phone ?? "",
            _form.Company,
            _form.ProjectType ?? "",
            _form.BudgetRange ?? "",
            _form.Timeline ?? "",
            _form.Message ?? "");

        bool success = await InquiryService.SubmitInquiryAsync(model);

        if (success)
        {
            _submitted = true;
        }
        else
        {
            _errorMessage = "Failed to submit inquiry. Please try again.";
        }

        _submitting = false;
    }

    private void Reset()
    {
        _submitted = false;
        _errorMessage = null;
        _form.Message = "";
        _form.Phone = null;
        _form.Company = null;
        _form.ProjectType = null;
        _form.BudgetRange = null;
        _form.Timeline = null;
    }

    private sealed class InquiryForm
    {
        public string? Name { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Company { get; set; }
        public string? ProjectType { get; set; }
        public string? BudgetRange { get; set; }
        public string? Timeline { get; set; }
        public string? Message { get; set; }
    }
}
