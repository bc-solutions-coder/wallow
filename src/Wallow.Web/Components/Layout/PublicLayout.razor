@inherits LayoutComponentBase
@inject Wallow.Web.Configuration.BrandingOptions Branding

<div class="min-h-screen flex flex-col bg-[#faf6f1]">
    <!-- Navbar -->
    <nav class="w-full px-6 py-4 flex items-center justify-between bg-[#faf6f1] border-b border-[#e8d5b7]">
        <a href="/" class="flex items-center gap-2 text-[#3d2b1f] font-bold text-xl no-underline">
            <img src="@Branding.AppIcon" alt="@Branding.AppName" class="size-8" style="shape-rendering: geometricPrecision;" />
            @Branding.AppName
        </a>
        <div class="flex items-center gap-6">
            <a href="/features" class="text-[#3d2b1f] hover:text-[#d4a017] no-underline text-sm font-medium">Features</a>
            <a href="https://github.com/wallowapp/wallow/tree/main/docs" target="_blank" class="text-[#3d2b1f] hover:text-[#d4a017] no-underline text-sm font-medium">Docs</a>
            <a href="https://github.com/wallowapp/wallow" target="_blank" class="text-[#3d2b1f] hover:text-[#d4a017] no-underline text-sm font-medium">GitHub</a>
        </div>
        <a href="/authentication/login?returnUrl=/dashboard/apps" class="bg-[#d4a017] text-white text-sm font-medium px-5 py-2 rounded-full hover:bg-[#b8880f] no-underline">
            Get Started
        </a>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
        @Body
    </main>

    <!-- Footer -->
    <footer class="bg-[#3d2b1f] text-white px-6 py-8">
        <div class="max-w-6xl mx-auto flex items-center justify-between text-sm">
            <span>MIT Licensed</span>
            <div class="flex items-center gap-6">
                <a href="https://github.com/wallowapp/wallow" target="_blank" class="text-white hover:text-[#d4a017] no-underline">GitHub</a>
                <a href="https://github.com/wallowapp/wallow/tree/main/docs" target="_blank" class="text-white hover:text-[#d4a017] no-underline">Docs</a>
            </div>
        </div>
    </footer>
</div>
