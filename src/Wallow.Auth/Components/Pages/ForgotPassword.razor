@page "/forgot-password"
@rendermode InteractiveServer
@inject IAuthApiClient AuthApi
@using Wallow.Auth.Configuration
@inject BrandingOptions Branding

<PageTitle>Forgot Password — @Branding.AppName</PageTitle>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Forgot your password?</BbCardTitle>
        <BbCardDescription>Enter your email address and we'll send you a reset link.</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        @if (_submitted)
        {
            <div data-testid="forgot-password-success">
                <BbAlert>
                    <BbAlertTitle>Check your email</BbAlertTitle>
                    <BbAlertDescription>If an account exists with that email, we've sent a password reset link.</BbAlertDescription>
                </BbAlert>
            </div>
        }
        else
        {
            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="text-sm font-medium text-foreground" for="forgot-email">Email</label>
                    <BbInput @bind-Value="_email" id="forgot-email" placeholder="you@example.com" data-testid="forgot-password-email" />
                </div>

                <BbButton Class="w-full" Disabled="_loading" OnClick="HandleSubmit" data-testid="forgot-password-submit">
                    @if (_loading)
                    {
                        <BbSpinner />
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send reset link</span>
                    }
                </BbButton>
            </div>
        }
    </BbCardContent>
    <BbCardFooter>
        <div class="text-center w-full">
            <a href="/login" class="text-sm text-muted-foreground hover:text-foreground">Back to sign in</a>
        </div>
    </BbCardFooter>
</BbCard>

@code {
    private string _email = string.Empty;
    private bool _loading;
    private bool _submitted;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            return;
        }

        _loading = true;

        try
        {
            await AuthApi.ForgotPasswordAsync(new ForgotPasswordRequest(_email));
            _submitted = true;
        }
        finally
        {
            _loading = false;
        }
    }
}
