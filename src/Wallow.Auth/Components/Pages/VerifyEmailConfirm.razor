@page "/verify-email/confirm"
@rendermode InteractiveServer
@inject IAuthApiClient AuthApi
@using Wallow.Auth.Configuration
@using Wallow.Auth.Helpers
@inject BrandingOptions Branding
@inject ILogger<VerifyEmailConfirm> Logger

<PageTitle>Verify Email — @Branding.AppName</PageTitle>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Email Verification</BbCardTitle>
    </BbCardHeader>
    <BbCardContent>
        @if (_loading)
        {
            <div data-testid="verify-email-confirm-loading" class="flex items-center justify-center py-4">
                <BbSpinner />
                <span class="ml-2 text-sm text-muted-foreground">Verifying your email...</span>
            </div>
        }
        else if (_succeeded)
        {
            <div data-testid="verify-email-confirm-success">
                <BbAlert>
                    <BbAlertTitle>Email verified!</BbAlertTitle>
                    <BbAlertDescription>Your email has been verified. You can now sign in.</BbAlertDescription>
                </BbAlert>
            </div>

            @if (ReturnUrlValidator.IsSafe(ReturnUrl))
            {
                <div class="mt-4">
                    <div data-testid="verify-email-confirm-continue">
                    <BbButton Class="w-full" Href="@ReturnUrl">Continue</BbButton>
                </div>
                </div>
            }
        }
        else
        {
            <div data-testid="verify-email-confirm-error">
                <BbAlert Variant="AlertVariant.Danger">
                    <BbAlertTitle>Verification failed</BbAlertTitle>
                    <BbAlertDescription>@_error</BbAlertDescription>
                </BbAlert>
            </div>
        }
    </BbCardContent>
    <BbCardFooter>
        <div class="text-center w-full">
            <a href="@LoginUrl" data-testid="verify-email-confirm-signin-link" class="text-sm text-muted-foreground hover:text-foreground">Go to sign in</a>
        </div>
    </BbCardFooter>
</BbCard>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string LoginUrl => ReturnUrlValidator.IsSafe(ReturnUrl)
        ? $"/login?returnUrl={Uri.EscapeDataString(ReturnUrl!)}"
        : "/login";

    private bool _loading = true;
    private bool _succeeded;
    private string _error = "The verification link is invalid or has expired.";

    protected override async Task OnInitializedAsync()
    {
        Logger.LogDebug("OIDC VerifyEmailConfirm: page initializing with email={Email}", Email);

        if (string.IsNullOrEmpty(Token) || string.IsNullOrEmpty(Email))
        {
            Logger.LogWarning("OIDC VerifyEmailConfirm: missing required parameters");
            _loading = false;
            _error = "Invalid verification link. Missing required parameters.";
            return;
        }

        try
        {
            Logger.LogDebug("OIDC VerifyEmailConfirm: verifying email for {Email}", Email);
            AuthResponse result = await AuthApi.VerifyEmailAsync(Email, Token);

            _succeeded = result.Succeeded;
            if (result.Succeeded)
            {
                Logger.LogInformation("OIDC VerifyEmailConfirm: email verification succeeded for {Email}", Email);
            }
            else
            {
                Logger.LogWarning("OIDC VerifyEmailConfirm: email verification failed for {Email} with error {Error}", Email, result.Error);
                _error = result.Error switch
                {
                    "invalid_token" => "The verification link is invalid or has expired.",
                    _ => "Failed to verify email. Please try again."
                };
            }
        }
        catch
        {
            _error = "An error occurred while verifying your email. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }
}
