@page "/verify-email"
@using Wallow.Auth.Configuration
@inject BrandingOptions Branding

<PageTitle>Verify Email — @Branding.AppName</PageTitle>

<BbCard>
    <BbCardHeader>
        <BbCardTitle><span data-testid="verify-email-heading">Check your email</span></BbCardTitle>
        <BbCardDescription><span data-testid="verify-email-description">We've sent a verification link to your email address.</span></BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        <p class="text-sm text-muted-foreground">
            Click the link in your email to verify your account. If you don't see it, check your spam folder.
        </p>
    </BbCardContent>
    <BbCardFooter>
        <div class="text-center w-full">
            <a href="@LoginUrl" data-testid="verify-email-back-link" class="text-sm text-muted-foreground hover:text-foreground">Back to sign in</a>
        </div>
    </BbCardFooter>
</BbCard>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string LoginUrl => string.IsNullOrEmpty(ReturnUrl)
        ? "/login"
        : $"/login?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
}
