@page "/reset-password"
@rendermode InteractiveServer
@inject IAuthApiClient AuthApi
@inject NavigationManager Navigation
@using Wallow.Auth.Configuration
@inject BrandingOptions Branding

<PageTitle>Reset Password — @Branding.AppName</PageTitle>

<BbCard>
    <BbCardHeader>
        <BbCardTitle>Reset your password</BbCardTitle>
        <BbCardDescription>Enter your new password below.</BbCardDescription>
    </BbCardHeader>
    <BbCardContent>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div data-testid="reset-password-error">
                <BbAlert Variant="AlertVariant.Danger" Class="mb-4">
                    <BbAlertDescription>@_error</BbAlertDescription>
                </BbAlert>
            </div>
        }

        <div class="space-y-4">
            <div class="space-y-2">
                <label class="text-sm font-medium text-foreground" for="new-password">New password</label>
                <input type="password" id="new-password" @bind="_newPassword" data-testid="reset-password-new-password"
                       class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" />
            </div>

            <div class="space-y-2">
                <label class="text-sm font-medium text-foreground" for="confirm-password">Confirm new password</label>
                <input type="password" id="confirm-password" @bind="_confirmPassword" data-testid="reset-password-confirm"
                       class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" />
            </div>

            <BbButton Class="w-full" Disabled="_loading" OnClick="HandleSubmit" data-testid="reset-password-submit">
                @if (_loading)
                {
                    <BbSpinner />
                    <span>Resetting...</span>
                }
                else
                {
                    <span>Reset password</span>
                }
            </BbButton>
        </div>
    </BbCardContent>
    <BbCardFooter>
        <div class="text-center w-full">
            <a href="/login" class="text-sm text-muted-foreground hover:text-foreground">Back to sign in</a>
        </div>
    </BbCardFooter>
</BbCard>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _loading;
    private string? _error;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(Token) || string.IsNullOrEmpty(Email))
        {
            _error = "Invalid reset link. Please request a new password reset.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _loading = true;
        _error = null;

        try
        {
            AuthResponse result = await AuthApi.ResetPasswordAsync(
                new ResetPasswordRequest(Email, Token, _newPassword));

            if (result.Succeeded)
            {
                Navigation.NavigateTo("/login?message=password_reset");
            }
            else
            {
                _error = result.Error switch
                {
                    "invalid_token" => "This reset link is invalid or has expired. Please request a new one.",
                    _ => "Failed to reset password. Please try again."
                };
            }
        }
        finally
        {
            _loading = false;
        }
    }
}
