<Project Sdk="Microsoft.NET.Sdk">

  <!-- TargetFramework, Nullable, etc. inherited from Directory.Build.props -->
  <!-- Package versions managed in Directory.Packages.props -->

  <PropertyGroup>
    <RootNamespace>Foundry.Shared.Kernel</RootNamespace>
  </PropertyGroup>

  <!-- Required for HasPermissionAttribute which uses AuthorizeAttribute -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- CQRS & Messaging -->
    <PackageReference Include="WolverineFx" />
    <PackageReference Include="WolverineFx.RabbitMQ" />
    <PackageReference Include="WolverineFx.FluentValidation" />

    <!-- Validation -->
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />

    <!-- EF Core (for strongly-typed ID converters) -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
  </ItemGroup>

</Project>
