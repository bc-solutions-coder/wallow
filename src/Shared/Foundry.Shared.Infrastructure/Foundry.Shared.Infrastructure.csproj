<Project Sdk="Microsoft.NET.Sdk">

  <!-- TargetFramework, Nullable, etc. inherited from Directory.Build.props -->
  <!-- Package versions managed in Directory.Packages.props -->

  <PropertyGroup>
    <RootNamespace>Foundry.Shared.Infrastructure</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Foundry.Shared.Kernel\Foundry.Shared.Kernel.csproj" />
    <ProjectReference Include="..\Foundry.Shared.Contracts\Foundry.Shared.Contracts.csproj" />
    <ProjectReference Include="..\Foundry.Shared.Infrastructure.Core\Foundry.Shared.Infrastructure.Core.csproj" />
    <ProjectReference Include="..\Foundry.Shared.Infrastructure.BackgroundJobs\Foundry.Shared.Infrastructure.BackgroundJobs.csproj" />
    <ProjectReference Include="..\Foundry.Shared.Infrastructure.Workflows\Foundry.Shared.Infrastructure.Workflows.csproj" />
    <ProjectReference Include="..\Foundry.Shared.Infrastructure.Plugins\Foundry.Shared.Infrastructure.Plugins.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Auditing -->
    <PackageReference Include="Audit.EntityFramework.Core" />

    <!-- EF Core + PostgreSQL -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />

    <!-- CQRS & Messaging -->
    <PackageReference Include="WolverineFx" />

    <!-- Logging -->
    <PackageReference Include="Serilog.AspNetCore" />

    <!-- HTML Sanitization -->
    <PackageReference Include="HtmlSanitizer" />

    <!-- Background Jobs -->
    <PackageReference Include="Hangfire.Core" />

    <!-- Workflow Engine (Elsa) -->
    <PackageReference Include="Elsa" />
    <PackageReference Include="Elsa.Workflows.Core" />
    <PackageReference Include="Elsa.Workflows.Management" />
    <PackageReference Include="Elsa.Workflows.Runtime" />
    <PackageReference Include="Elsa.Workflows.Api" />
    <PackageReference Include="Elsa.EntityFrameworkCore.PostgreSql" />
    <PackageReference Include="Elsa.Identity" />
    <PackageReference Include="Elsa.Scheduling" />
    <PackageReference Include="Elsa.Email" />
    <PackageReference Include="Elsa.Http" />
  </ItemGroup>

</Project>
