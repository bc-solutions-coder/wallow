{
  "name": "@wallow/sdk",
  "version": "0.0.0",
  "description": "Wallow TypeScript browser SDK with BFF tunnel",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.7.0",
    "h3": "^1.13.0",
    "iron-webcrypto": "^1.2.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.64.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
