{
  "name": "@bc-solutions-coder/web-shell",
  "version": "0.0.0",
  "private": true,
  "description": "Wallow standalone host runtime + shared Vite/dev-server config presets",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bc-solutions-coder/styles": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/router-plugin": "^1.168.20",
    "@vitejs/plugin-react": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
