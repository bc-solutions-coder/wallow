{
  "name": "@bc-solutions-coder/sdk",
  "version": "0.0.0",
  "description": "Wallow TypeScript browser SDK with BFF tunnel",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.8.4",
    "@tanstack/react-query": "^5.101.2",
    "h3": "^1.13.0",
    "iron-webcrypto": "^1.2.1",
    "openid-client": "^6.1.7"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.64.0",
    "@types/node": "^22.20.0",
    "tsx": "^4.19.0",
    "typescript": "6.0.3",
    "vite": "^8.1.4",
    "vitest": "^2.1.0"
  }
}
